<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>⚡ Smart Solve AI — Intelligent Project Planner</title>
<link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Space+Mono:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="{{ url_for('static', filename='style.css') }}">
<link rel="stylesheet" href="{{ url_for('static', filename='animations.css') }}">
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
</head>
<body>

<!-- Ambient background -->
<div class="bg-canvas" aria-hidden="true">
  <div class="bg-grid"></div>
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>
  <div class="scan-line"></div>
</div>

<!-- ══════════════════ HEADER ══════════════════ -->
<header class="site-header">
  <div class="header-inner">
    <div class="logo-group">
      <div class="logo-icon">⚡</div>
      <div>
        <h1 class="logo-text">SMART SOLVE AI</h1>
        <div class="logo-sub">Intelligent Project Planning System</div>
      </div>
    </div>
    <div class="header-badges">
      <span class="badge badge-live"><span class="live-dot"></span>AI ONLINE</span>
      <span class="badge badge-ver">v2.0</span>
      <button class="btn-history-toggle" onclick="toggleHistory()" title="Project History">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 3h6l3 3h9a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2z"/></svg>
        History
      </button>
    </div>
  </div>
</header>

<!-- ══════════════════ HISTORY DRAWER ══════════════════ -->
<div id="history-drawer" class="history-drawer hidden">
  <div class="history-header">
    <span class="section-label">RECENT PROJECTS</span>
    <button class="btn-close" onclick="toggleHistory()">✕</button>
  </div>
  <div id="history-list" class="history-list">
    <p class="empty-msg">No projects yet. Generate your first plan!</p>
  </div>
</div>

<!-- ══════════════════ MAIN ══════════════════ -->
<main class="main-container">

  <!-- ── INPUT PANEL ── -->
  <section class="input-panel glass-card anim-fade-up">

    <div class="panel-header">
      <div class="section-label">01 · DEFINE YOUR PROJECT</div>
    </div>

    <div class="input-grid">

      <!-- Problem -->
      <div class="field-group field-wide">
        <label class="field-label" for="problem">
          <span class="label-icon">◈</span> Problem Statement
        </label>
        <textarea id="problem" class="field-textarea" rows="5"
          placeholder="Describe your project challenge or goal in detail...&#10;&#10;Example: Build a real-time collaborative document editor with AI writing assistance, user authentication, version history, and mobile support within 6 weeks."></textarea>
        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 8px;">
          <div class="char-count" id="char-count">0 / 1000</div>
          <button id="btn-analyze" class="btn-analyze" onclick="analyzeProblem()" style="background: rgba(43, 88, 204, 0.2); border: 1px solid rgba(138, 180, 248, 0.3); color: #8ab4f8; padding: 4px 12px; border-radius: 4px; cursor: pointer; font-family: 'Space Mono', monospace; font-size: 0.8rem; transition: all 0.2s;">
            <span class="btn-icon-wrap" style="margin-right: 4px;">🔍</span> Analyze & Get Ideas
          </button>
        </div>
        <div id="analyze-results" style="display: none; margin-top: 12px; padding: 12px; border-radius: 6px; background: rgba(20, 25, 40, 0.6); border: 1px dashed rgba(138, 180, 248, 0.2); font-size: 0.85rem;">
          <!-- Results will be injected here -->
        </div>
      </div>

      <!-- Team -->
      <div class="field-group">
        <label class="field-label">
          <span class="label-icon">◈</span> Team Members &amp; Skills
        </label>
        <div id="team-list"></div>
        <button class="btn-add-member" onclick="addMember()">
          <span>+</span> Add Team Member
        </button>
      </div>

    </div>

    <!-- Options row -->
    <div class="options-row">
      <div class="field-group field-inline">
        <label class="field-label" for="deadline">
          <span class="label-icon">◈</span> Deadline <span class="optional">(optional)</span>
        </label>
        <input type="text" id="deadline" class="field-input" placeholder="e.g. 3 weeks, 30 days, 2 months">
      </div>
      <div class="field-group field-inline">
        <label class="field-label">
          <span class="label-icon">◈</span> AI Mode
        </label>
        <div id="ai-mode-badge" class="ai-mode-badge">Loading…</div>
      </div>
    </div>

    <!-- CTA -->
    <button class="btn-generate" id="gen-btn" onclick="generatePlan()">
      <span class="btn-glow"></span>
      <span class="btn-content">
        <span class="btn-icon-wrap">⚡</span>
        <span class="btn-text">GENERATE AI PROJECT PLAN</span>
        <span class="btn-arrow">→</span>
      </span>
    </button>

    <div id="error-box" class="error-box hidden"></div>

  </section>

  <!-- ── LOADING ── -->
  <div id="loading-panel" class="loading-panel hidden">
    <div class="loader-core">
      <div class="loader-rings">
        <div class="ring ring-1"></div>
        <div class="ring ring-2"></div>
        <div class="ring ring-3"></div>
        <div class="loader-center">AI</div>
      </div>
    </div>
    <div class="loader-text" id="loader-step">INITIALIZING</div>
    <div class="loader-sub" id="loader-sub">Connecting to AI engine...</div>
    <div class="loader-progress">
      <div class="loader-bar" id="loader-bar"></div>
    </div>
  </div>

  <!-- ══ OUTPUT SECTION ══ -->
  <div id="output-section" class="output-section hidden">

    <!-- Project title + meta -->
    <div class="project-header glass-card anim-fade-up">
      <div class="project-meta">
        <div class="project-id-badge" id="proj-id-badge">ID: ——</div>
        <div class="project-timestamp" id="proj-time"></div>
      </div>
      <h2 class="project-title" id="proj-title">Project Plan</h2>
      <p class="project-summary" id="proj-summary"></p>
    </div>

    <!-- Stats row -->
    <div class="stats-row" id="stats-row"></div>

    <!-- Charts row -->
    <div class="charts-row">
      <div class="glass-card chart-card anim-fade-up">
        <div class="card-header">
          <span class="section-label">TASK BREAKDOWN</span>
        </div>
        <div class="chart-wrap"><canvas id="typeChart"></canvas></div>
        <div id="type-legend" class="chart-legend"></div>
      </div>
      <div class="glass-card chart-card anim-fade-up">
        <div class="card-header">
          <span class="section-label">WORKLOAD DISTRIBUTION</span>
        </div>
        <div class="chart-wrap"><canvas id="workloadChart"></canvas></div>
      </div>
    </div>

    <!-- Gantt -->
    <div class="glass-card gantt-card anim-fade-up">
      <div class="card-header">
        <span class="section-label">TIMELINE · GANTT CHART</span>
        <span class="card-note" id="gantt-note"></span>
      </div>
      <div class="gantt-scroll-wrap" id="gantt-wrap"></div>
    </div>

    <!-- Task board -->
    <div class="glass-card tasks-card anim-fade-up">
      <div class="card-header tasks-header">
        <div>
          <span class="section-label">TASK BOARD</span>
          <span class="edit-hint">· click task title to edit</span>
        </div>
        <div class="filter-bar" id="filter-bar"></div>
      </div>
      <div id="task-list" class="task-list"></div>
    </div>

  </div><!-- /output-section -->

</main>

<script src="{{ url_for('static', filename='script.js') }}"></script>
</body>
</html>
